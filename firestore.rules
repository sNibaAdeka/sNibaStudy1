rules_version = '2';

// Deploy these rules in Firebase Console → Firestore → Rules
// Or via: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for friend search)
      allow read: if request.auth != null;

      // Users can only write their own document
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Study rooms
    match /rooms/{roomId} {
      // Any authenticated user can read rooms
      allow read: if request.auth != null;

      // Any authenticated user can create a room
      allow create: if request.auth != null;

      // Any authenticated user can update (join/leave)
      allow update: if request.auth != null;

      // Only the creator can delete
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }
  }
}
